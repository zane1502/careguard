{
  "name": "careguard",
  "version": "1.0.0",
  "description": "AI agent for elderly care financial coordination on Stellar",
  "main": "index.js",
  "scripts": {
    "setup": "node --import tsx scripts/setup-wallets.ts",
    "pharmacy-api": "node --import tsx services/pharmacy-api/server.ts",
    "bill-audit-api": "node --import tsx services/bill-audit-api/server.ts",
    "drug-api": "node --import tsx services/drug-interaction-api/server.ts",
    "agent": "node --import tsx agent/server.ts",
    "pharmacy-payment": "node --import tsx services/pharmacy-payment/server.ts",
    "services": "concurrently --kill-others-on-fail \"npm run pharmacy-api\" \"npm run bill-audit-api\" \"npm run drug-api\" \"npm run pharmacy-payment\"",
    "start": "node --import tsx server.ts",
    "dev": "node --import tsx server.ts",
    "typecheck": "tsc -b",
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "gen-openapi": "node --import tsx scripts/gen-openapi.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "load": "k6 run load/agent-run.js",
    "check:env-vars": "tsx scripts/check-env-vars.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@sentry/node": "^8.45.1",
    "@stellar/mpp": "^0.4.0",
    "@stellar/stellar-sdk": "^14.6.1",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-virtual": "^3.14.4",
    "@x402/core": "^2.11.0",
    "@x402/express": "^2.11.0",
    "@x402/fetch": "^2.11.0",
    "@x402/stellar": "^2.11.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "glob": "^11.0.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.6.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "mppx": "^0.6.5",
    "next": "^16.2.9",
    "node-cron": "^3.0.3",
    "openai": "^6.36.0",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "proper-lockfile": "^4.1.2",
    "rate-limit-redis": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "ioredis-mock": "^8.9.0",
    "jsdom": "^25.0.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "supertest": "^7.2.2",
    "typescript": "5.8.3",
    "vitest": "^2.1.8"
  }
}
